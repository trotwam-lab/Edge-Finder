# Local environment variables for EdgeFinder
# Copy your actual API keys here for local testing

# Required for Odds API
ODDS_API_KEY=your_odds_api_key_here

# Optional trial override: when enabled, /api/odds, /api/props, and /api/edges
# prefer SportsGameOdds for supported leagues and fall back to ODDS_API_KEY when
# disabled. Remove/toggle this on the 2026-07-18 trial review.
# SPORTSGAMEODDS_ENABLED=true
# SPORTSGAMEODDS_API_KEY=your_sportsgameodds_key_here

# Optional: OpenWeatherMap (used for MLB weather in game research)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: Ball Don't Lie API (free tier works without key)
# BALLDONTLIE_API_KEY=your_bdl_key_here

# Optional: Stripe (for testing payments locally)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# DEV ONLY — lets the unverified X-EdgeFinder-Email header grant Pro when
# Firebase Admin isn't configured locally. NEVER set this in production:
# it makes Pro data spoofable with a single header.
# ALLOW_EMAIL_TIER_FALLBACK=true
