{
  "sports": {
    "mlb": {
      "display_name": "MLB",
      "cadence": "daily",
      "timezone_anchor": "America/New_York",
      "slots": {
        "schedule": {
          "primary": {
            "source": "odds_api",
            "endpoint": "/api/odds",
            "sport_key": "baseball_mlb"
          },
          "secondary": {
            "source": "mlb_statsapi",
            "endpoint": "/api/mlb-statsapi",
            "note": "statsapi.mlb.com schedule — source of truth for probables"
          }
        },
        "availability": {
          "primitive": "confirmed_lineups",
          "primary": {
            "source": "mlb_statsapi",
            "endpoint": "/api/mlb-statsapi",
            "note": "official posted lineups + probable starters"
          },
          "secondary": {
            "source": "rotowire",
            "path": "/baseball/daily-lineups.php",
            "note": "faster than StatsAPI on late scratches; already trusted by game-research-baseball"
          },
          "fields": ["confirmed", "probable_pitcher", "lineup", "thesis_anchor_scratched"],
          "sport_specific": {
            "probable_pitcher": "starter confirmation is the thesis anchor for most MLB edges",
            "bullpen_usage": "flag if projected high-leverage arms threw 25+ pitches yesterday",
            "weather": "wind/park check for totals edges only"
          }
        },
        "form": {
          "primary": {
            "source": "fangraphs",
            "metrics": ["wRC+", "xFIP", "SIERA", "K-BB%"]
          },
          "secondary": {
            "source": "baseball_savant",
            "metrics": ["xwOBA", "barrel_rate", "hard_hit_rate"]
          }
        },
        "freshness": {
          "trigger_type": "cron_plus_gate",
          "base_refresh": "0 10 * * *",
          "publish_gate": "confirmed_lineups_posted",
          "gate_notes": "Lineups typically post 2-4h before first pitch; starter edges stay PENDING until the card is up.",
          "checkpoints": [
            { "at": "T-60min", "action": "re-check lineup card for scratches and pitcher changes" }
          ]
        }
      }
    },

